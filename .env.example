# ── Chatwoot ──────────────────────────────────────────────
CHATWOOT_URL=http://localhost:3000

# Token del Agent Bot (para que las respuestas aparezcan como "Mi AI Bot")
CHATWOOT_BOT_TOKEN=x3ZqMmuo6RZbdJiWdXNjiFmF

# Token de usuario (Personal Access Token) para LEER mensajes.
# Si no se define, usa CHATWOOT_BOT_TOKEN (pero el bot no puede leer historial).
# Para obtenerlo: Settings → Profile → Personal Access Tokens en Chatwoot
# CHATWOOT_READ_TOKEN=tu_token_de_usuario

# ── Modo del agente ───────────────────────────────────────
# direct | openai | ollama
AGENT_MODE=direct

# ── Contexto de conversacion ──────────────────────────────
# true  → el bot obtiene el historial completo de la conversacion
# false → responde solo el ultimo mensaje
ENABLE_CONTEXT=true

# ── OpenAI / Groq / Google Gemini ─────────────────────────
# OPENAI_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Groq:
# OPENAI_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.3-70b-versatile

# Google Gemini:
# OPENAI_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_API_KEY=AIza...
# OPENAI_MODEL=gemini-2.0-flash

# ── Ollama ────────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
